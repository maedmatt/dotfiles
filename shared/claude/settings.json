{
  "env": {},
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Bash(obsidian *)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'export PATH=/Library/TeX/texbin:/usr/local/bin:/usr/bin:/bin:$PATH; FILE=$(jq -r \".tool_input.file_path\" <<< \"$(cat)\"); if [[ \"$FILE\" == *.tex ]]; then cd \"$(dirname \"$FILE\")\" && latexmk -pdf -quiet \"$(basename \"$FILE\")\" 2>&1 | tail -5; fi; exit 0'",
            "timeout": 60,
            "statusMessage": "Compiling LaTeX"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest"
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "showThinkingSummaries": true,
  "theme": "auto",
  "verbose": true,
  "preferredNotifChannel": "ghostty",
  "skipAutoPermissionPrompt": true
}
