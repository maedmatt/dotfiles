{
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "400000"
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Bash(obsidian *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'export PATH=/Library/TeX/texbin:/usr/local/bin:/usr/bin:/bin:$PATH; FILE=$(jq -r \".tool_input.file_path\" <<< \"$(cat)\"); if [[ \"$FILE\" == *.tex ]]; then cd \"$(dirname \"$FILE\")\" && latexmk -pdf -quiet \"$(basename \"$FILE\")\" 2>&1 | tail -5; fi; exit 0'",
            "timeout": 60,
            "statusMessage": "Compiling LaTeX"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/matteo/.bun/bin/bunx -y ccstatusline@latest"
  },
  "effortLevel": "xhigh",
  "advisorModel": "opus",
  "showThinkingSummaries": true,
  "defaultMode": "default"
}
